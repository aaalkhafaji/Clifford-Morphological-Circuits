# Zip and Download
# ==========================================
pdf_files = [
    'Fig9_NonReciprocity.pdf', 
    'Fig10_EdgeLocalization.pdf', 
    'Fig11_MemristiveDiffusion.pdf'
]

zip_name = 'Clifford_Validation_Figures.zip'

